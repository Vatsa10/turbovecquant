# Copy to .env and fill in only the providers you'll actually use.
# Every entry is optional — live tests for a provider skip automatically
# when its key is missing.

# ---- LLM completion providers ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# ---- Embedding providers ----
# OPENAI_API_KEY also covers OpenAI embeddings.
COHERE_API_KEY=
VOYAGE_API_KEY=

# ---- Infrastructure ----
# Redis / Memurai. Default localhost is fine for dev.
REDIS_URL=redis://localhost:6379/0

# ---- Optional ----
# Raises anonymous HuggingFace download rate limits when fetching
# benchmark datasets.
HUGGING_FACE_HUB_TOKEN=

# Model overrides for the live test suite. Defaults are the cheapest
# usable model on each provider.
TURBOVEC_LIVE_OPENAI_CHAT_MODEL=gpt-4o-mini
TURBOVEC_LIVE_OPENAI_EMBED_MODEL=text-embedding-3-small
TURBOVEC_LIVE_ANTHROPIC_MODEL=claude-haiku-4-5
TURBOVEC_LIVE_GEMINI_MODEL=gemini-2.0-flash
